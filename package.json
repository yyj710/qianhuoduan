{
  "name": "chuangyin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prisma:generate": "node -e \"const fs=require('fs');fs.cpSync('backend/prisma/schema.prisma','prisma/schema.prisma')\" && npx prisma generate",
    "prisma:push": "npx prisma db push --accept-data-loss --schema=backend/prisma/schema.prisma",
    "build:frontend": "cd frontend && npm install && npx vite build",
    "build:backend": "cd backend && npm install && npm run build",
    "build:function": "npx esbuild build-function-entry.mjs --bundle --platform=node --format=cjs --outfile=netlify/functions/api.js --external:@prisma/client",
    "build": "npm run prisma:generate && npm run build:frontend && npm run build:backend && npm run build:function",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "serverless-http": "^4.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "prisma": "^5.22.0"
  }
}
